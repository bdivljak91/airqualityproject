pins.i2cWriteNumber(\n    90,\n    2,\n    NumberFormat.UInt8BE,\n    false\n    )\n    let data = pins.i2cReadBuffer(0x5A, 4)\nlet eCO2 = (data[0] << 8) | data[1]\nlet TVOC = (data[2] << 8) | data[3]\nkvalitetVazduha = eCO2\n}\nfunction alarm () {\n    for (let index = 0; index < 4; index++) {\n        music.play(music.tonePlayable(392, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)\n        music.play(music.tonePlayable(784, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)\n    }\n}\nfunction inicijalizujCCS811 () {\n    pins.i2cWriteBuffer(0x5A, pins.createBufferFromArray([0x01, 0x10]))\n}\nfunction kompenzujCCS811 () {\n    hum = vlaznostVazduha * 512\n    temp = (temperatura + 25) * 512\n    let humHigh = (hum >> 8) & 0xFF\nlet humLow = hum & 0xFF\nlet tempHigh = (temp >> 8) & 0xFF\nlet tempLow = temp & 0xFF\nlet buffer = pins.createBuffer(5)\nbuffer[0] = 5\n    buffer[1] = humHigh\n    buffer[2] = humLow\n    buffer[3] = tempHigh\n    buffer[4] = tempLow\n    pins.i2cWriteBuffer(0x5A, buffer)\n}\nbasic.forever(function () {\n    BME280.PowerOn()\n    inicijalizujCCS811()\n    ocitajOkruzenje()\n    kompenzujCCS811()\n    ocitajKvalitetVazduha()\n    if (kvalitetVazduha < 800) {\n        basic.showIcon(IconNames.Happy)\n    } else {\n        if (kvalitetVazduha < 1200) {\n            basic.showIcon(IconNames.Asleep)\n        } else {\n            basic.showIcon(IconNames.Sad)\n            alarm()\n        }\n    }\n    serial.writeValue(\"temp\", temperatura)\n    serial.writeValue(\"hum\", vlaznostVazduha)\n    serial.writeValue(\"press\", pritisak)\n    serial.writeValue(\"eco2\", kvalitetVazduha)\n    basic.pause(1000)\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"AirQualityProject\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"BME280\": \"github:makecode-extensions/bme280#v1.1.0\"\n    },\n    \"files\": [\n      