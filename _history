et_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P8</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value></block></statement></block><block type=\"function_definition\" x=\"2649\" y=\"1447\"><mutation name=\"upaliZelenuLampicu\" functionid=\"Gho+)A(W}E0G?L:d:.KX\"></mutation><field name=\"function_name\">upaliZelenuLampicu</field><statement name=\"STACK\"><block type=\"device_set_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P1</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" precision=\"0\"></mutation><field name=\"SLIDER\">1</field></shadow></value></block></statement></block><block type=\"function_definition\" x=\"0\" y=\"2045\"><mutation name=\"ugasiZelenuLampicu\" functionid=\"6./M)!P[ph|r(Uw6{-}%\"></mutation><field name=\"function_name\">ugasiZelenuLampicu</field><statement name=\"STACK\"><block type=\"device_set_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P1</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value></block></statement></block></xml>","main.ts":"function ocitajOkruzenje () {\n    temperatura = BME280.temperature(BME280_T.T_C)\n    vlaznostVazduha = BME280.humidity()\n    pritisak = BME280.pressure(BME280_P.Pa)\n}\nfunction ocitajKvalitetVazduha () {\n    pins.i2cWriteNumber(\n        90,\n        2,\n        NumberFormat.UInt8BE,\n        true\n    )\n    let data = pins.i2cReadBuffer(0x5A, 4)\n    if (data.length == 4) {\n        eCO2 = (data[0] << 8) | data[1]\n        TVOC = (data[2] << 8) | data[3]\n    }\n}\nfunction startCCS811 () {\n    pins.i2cWriteNumber(\n    90,\n    244,\n    NumberFormat.UInt8BE,\n    false\n    )\n}\nfunction upaliCrvenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P8, 1)\n}\nfunction ugasiCrvenuLampicu() {\n    pins.digitalWritePin(DigitalPin.P8, 0)\n}\nfunction upaliZelenuLampicu() {\n    pins.digitalWritePin(DigitalPin.P1, 1)\n}\nfunction ugasiZelenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P1, 0)\n}\nfunction upaliZutuLampicu() {\n    pins.digitalWritePin(DigitalPin.P2, 1)\n}\nfunction ugasiZutuLampicu () {\n    pins.digitalWritePin(DigitalPin.P2, 0)\n}\nfunction inicijalizujCCS811() {\n    pins.i2cWriteBuffer(0x5A, pins.createBufferFromArray([0x01, 0x10]))\n}\nfunction kompenzujCCS811 () {\n    hum = vlaznostVazduha * 512\n    temp = (temperatura + 25) * 512\n    let buffer = pins.createBuffer(5)\nbuffer[0] = 5\n    buffer[1] = (hum >> 8) & 0xFF\n    buffer[2] = hum & 0xFF\n    buffer[3] = (temp >> 8) & 0xFF\n    buffer[4] = temp & 0xFF\n    pins.i2cWriteBuffer(0x5A, buffer)\n}\nfunction alarmJednom() {\n    // music.playTone(784, 200)\n    // basic.pause(100)\n    // music.playTone(784, 200)\n    // basic.pause(100)\n    // music.playTone(784, 200)\n  \n    music.playTone(523, 120) // C\n    basic.pause(80)\n    music.playTone(659, 120) // E\n    basic.pause(80)\n    music.playTone(784, 120) // G\n    \n}\nlet counter = 0\nlet pritisak = 0\nlet vlaznostVazduha = 0\nlet temperatura = 0\nlet eCO2 = 0\nlet TVOC = 0\nlet hum = 0\nlet temp = 0\nlet prethodnoStanje = 0 // 0=zelena, 1=zuta, 2=crvena\nstartCCS811()\nbasic.pause(2000)\ninicijalizujCCS811()\nbasic.pause(1000)\n\nbasic.forever(function () {\n    ocitajOkruzenje()\n    counter += 1\n    let trenutnoStanje = 0\n    if (counter % 5 == 0) {\n        kompenzujCCS811()\n    }\n    ocitajKvalitetVazduha()\n    if (eCO2 > 1000 || TVOC > 200 || vlaznostVazduha > 60) {\n        basic.showIcon(IconNames.Sad)\n        upaliCrvenuLampicu()\n        ugasiZutuLampicu()\n        ugasiZelenuLampicu()\n        trenutnoStanje = 2\n        if (prethodnoStanje != 2) {\n            alarmJednom()\n        }\n    } else if (eCO2 > 600 || TVOC > 100 || vlaznostVazduha > 45) {\n        basic.showIcon(IconNames.Asleep)\n        ugasiCrvenuLampicu()\n        upaliZutuLampicu()\n        ugasiZelenuLampicu()\n        trenutnoStanje = 1\n    } else {\n        basic.showIcon(IconNames.Happy)\n        ugasiCrvenuLampicu()\n        ugasiZutuLampicu()\n        upaliZelenuLampicu()\n        trenutnoStanje = 0\n    }\n    prethodnoStanje = trenutnoStanje\n    basic.pause(1000)\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"AirQualityProject\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"microphone\": \"*\",\n        \"BME280\": \"github:makecode-extensions/bme280#v1.1.0\",\n        \"bluetooth\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"yotta\": {\n        \"config\": {\n            \"microbit-dal\": {\n                \"bluetooth\": {\n                    \"open\": 0,\n                    \"whitelist\": 1,\n                    \"security_level\": \"SECURITY_MODE_ENCRYPTION_NO_MITM\"\n                }\n            }\n        }\n    }\n}\n"}},{"timestamp":1774102713217,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"|IKDm(2xgckC$%Sq%46?\">temperatura</variable><variable id=\"9VTsFQdV=S$r6vBqzQ?5\">vlaznostVazduha</variable><variable id=\"XLmR7B4wn72=EZpUuaVo\">pritisak</variable><variable id=\"{5xdG+`e9BHvEExu%puM\">hum</variable><variable id=\"h@GMfh-K#0/a^}zD]9Ah\">temp</variable><variable id=\"/YF$q=w.L/a)vzpTI/[#\">buffer</variable><variable id=\";OGCu]0A`Io)$T3@yie{\">eCO2</variable><variable id=\"H{:lIrnT;*r=(-o8U@kr\">eCO2_avg</variable><variable id=\"{s!rH5%F:p7L6tM3gdP.\">TVOC</variable><variable id=\"CAmeOW$R_Ucm~Eb^F+r1\">TVOC_avg</variable><variable id