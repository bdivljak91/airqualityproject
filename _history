GET_TEMPERATURE\"><field name=\"u\">BME280_T.T_C</field></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"H?VIu_mq=O|@!TgjM[n,\">vlaznostVazduha</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"BME280_GET_HUMIDITY\"></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"#RI[Y?a~F:5h|/HTmx=u\">pritisak</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"BME280_GET_PRESSURE\"><field name=\"u\">BME280_P.Pa</field></block></value></block></next></block></next></block></statement></block></xml>","main.ts":"function ocitajOkruzenje () {\n    temperatura = BME280.temperature(BME280_T.T_C)\n    vlaznostVazduha = BME280.humidity()\n    pritisak = BME280.pressure(BME280_P.Pa)\n}\nfunction ocitajKvalitetVazduha () {\n    pins.i2cWriteNumber(\n    90,\n    2,\n    NumberFormat.UInt8BE,\n    true\n    )\n    let data = pins.i2cReadBuffer(0x5A, 4)\neCO2 = (data[0] << 8) | data[1]\nTVOC = (data[2] << 8) | data[3]\n}\nfunction alarm () {\n    for (let index = 0; index < 4; index++) {\n        music.play(music.tonePlayable(392, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)\n        music.play(music.tonePlayable(784, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)\n    }\n}\nfunction startCCS811 () {\n    pins.i2cWriteNumber(\n    90,\n    244,\n    NumberFormat.UInt8BE,\n    false\n    )\n}\nfunction upaliCrvenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P0, 1)\n}\nfunction ugasiZelenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P1, 0)\n}\nfunction inicijalizujCCS811 () {\n    pins.i2cWriteBuffer(0x5A, pins.createBufferFromArray([0x01, 0x10]))\n}\nfunction ugasiCrvenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P0, 0)\n}\nfunction kompenzujCCS811 () {\n    hum = vlaznostVazduha * 512\n    temp = (temperatura + 25) * 512\n    let buffer = pins.createBuffer(5)\nbuffer[