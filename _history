ck></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"function ocitajOkruzenje () {\n    temperatura = BME280.temperature(BME280_T.T_C)\n    vlaznostVazduha = BME280.humidity()\n    pritisak = BME280.pressure(BME280_P.Pa)\n}\nfunction ocitajKvalitetVazduha () {\n    pins.i2cWriteNumber(\n    90,\n    2,\n    NumberFormat.UInt8BE,\n    true\n    )\n    let data = pins.i2cReadBuffer(0x5A, 4)\neCO2 = (data[0] << 8) | data[1]\nTVOC = (data[2] << 8) | data[3]\n}\nfunction upaliZutuLampicu () {\n    pins.digitalWritePin(DigitalPin.P2, 1)\n}\nfunction alarm () {\n    control.inBackground(function () {\n        while (true) {\n            if (alarmAktivan) {\n                music.playTone(784, 200)\n                basic.pause(200)\n            } else {\n                basic.pause(200)\n            }\n        }\n    })\n}\nfunction posaljiPodatkeBluetooth () {\n    json = \"{\\\"temp\\\":\" + temperatura + \",\\\"hum\\\":\" + vlaznostVazduha + \",\\\"pres\\\":\" + pritisak + \",\\\"co2\\\":\" + eCO2 + \",\\\"tvoc\\\":\" + TVOC + \"}\"\n    bluetooth.uartWriteLine(json)\n}\nfunction startCCS811 () {\n    pins.i2cWriteNumber(\n    90,\n    244,\n    NumberFormat.UInt8BE,\n    false\n    )\n}\nfunction upaliCrvenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P0, 1)\n}\nfunction ugasiZelenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P1, 0)\n}\nfunction inicijalizujCCS811 () {\n    pins.i2cWriteBuffer(0x5A, pins.createBufferFromArray([0x01, 0x10]))\n}\nfunction ugasiZutuLampicu () {\n    pins.digitalWritePin(DigitalPin.P2, 0)\n}\nfunction ugasiCrvenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P0, 0)\n}\nfunction kompenzujCCS811 () {\n    hum = vlaznostVazduha * 512\n    temp = (temperatura + 25) * 512\n    let buffer = pins.createBuffer(5)\nbuffer[0] = 5\n    buffer[1] = (hum >> 8) & 0xFF\n    buffer[2] = hum & 0xFF\n    buffer[3] = (temp >> 8) & 0xFF\n    buffer[4] = temp & 0xFF\n    pins.i2cWriteBuffer(0x5A, buffer)\n}\nfunction upaliZelenuLampicu () {\n    pins.digitalWritePin(DigitalPin.P1, 1)\n}\nlet counter = 0\nlet json = \"\"\nlet pritisak = 0\nlet vlaznostVazduha = 0\nlet temperatura = 0\nlet eCO2 = 0\nlet TVOC = 0\nlet temp2 = 0\nlet hum2 = 0\nlet hum3 = 0\nlet temp3 = 0\nlet hum = 0\nlet temp = 0\nlet alarmAktivan = false\nBME280.PowerOn()\nstartCCS811()\nbasic.pause(100)\ninicijalizujCCS811()\nbasic.pause(1000)\nbluetooth.startUartService()\n// alarm()\nbasic.forever(function () {\n    ocitajOkruzenje()\n    counter += 1\n    if (counter % 5 == 0) {\n        kompenzujCCS811()\n    }\n    ocitajKvalitetVazduha()\n    if (eCO2 > 1000 || TVOC > 200 || vlaznostVazduha > 60) {\n        basic.showIcon(IconNames.Sad)\n        upaliCrvenuLampicu()\n        ugasiZutuLampicu()\n        ugasiZelenuLampicu()\n        alarmAktivan = true\n    } else if (eCO2 > 600 || TVOC > 100 || vlaznostVazduha > 45) {\n        basic.showIcon(IconNames.Asleep)\n        ugasiCrvenuLampicu()\n        upaliZutuLampicu()\n        ugasiZelenuLampicu()\n        alarmAktivan = false\n    } else {\n        basic.showIcon(IconNames.Happy)\n        ugasiCrvenuLampicu()\n        ugasiZutuLampicu()\n        upaliZelenuLampicu()\n        alarmAktivan = false\n    }\n    // posaljiPodatkeBluetooth()\n    serial.writeValue(\"temp\", temperatura)\n    serial.writeValue(\"hum\", vlaznostVazduha)\n    serial.writeValue(\"press\", pritisak)\n    serial.writeValue(\"eco2\", eCO2)\n    serial.writeValue(\"TVOC\", TVOC)\n    basic.pause(1000)\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"AirQualityProject\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"microphone\": \"*\",\n        \"BME280\": \"github:makecode-extensions/bme280#v1.1.0\",\n        \"bluetooth\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"yotta\": {\n        \"config\": {\n            \"microbit-dal\": {\n                \"bluetooth\": {\n                    \"open\": 0,\n                    \"whitelist\": 1,\n                    \"security_level\": \"SECURITY_MODE_ENCRYPTION_NO_MITM\"\n                }\n            }\n        }\n    }\n}\n"}},{"timestamp":1773682480428,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\".s![7c96Gj:RVbnyjT!A\">temperatura</variable><variable id=\"P@n0@LXi|@btx[!!xxy{\">vlaznostVazduha</variable><variable id=\"id[`=sBes?|*)|WZ5H!o\">pritisak</variable><variable id=\"hm=L4*.?yQ=gt7/=cx70\">hum</variable><variable id=\"7!gC~p-%?Rpl)fmKjF{8\">temp</variable><variable id=\"6#,|OCP]N`T?3UJ1Ua^]\">buffer</variable><variable id=\"Cx{?Qv9PU|lmfidTpfp*\">counter</variable><variable id=\"|or*tq(+XQLAfEF#BDNL\">eCO2</variable><variable id=\"^z8ZD`tw~P)RVQ~3Mi;l\">TVOC</variable><variable id=\"wt+Gpk@b-/]d(bMh2reP\">alarmAktivan</variable></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"><statement name=\"HANDLER\"><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let eCO2 = 0\" numlines=\"1\" declaredvars=\"eCO2\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let TVOC = 0\" numlines=\"1\" declaredvars=\"TVOC\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let hum = 0\" numlines=\"1\" declaredvars=\"hum\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let temp = 0\" numlines=\"1\" declaredvars=\"temp\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"let alarmAktivan = false\" numlines=\"1\" declaredvars=\"alarmAktivan\"></mutation><next><block type=\"function_call\"><mutation name=\"startCCS811\" functionid=\"4X{+